# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Authorized User IDs (comma-separated for multiple users)
AUTHORIZED_USER_IDS=your_telegram_user_id_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Gemini API URL
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash

# GitHub Token
GITHUB_TOKEN=your_github_token

# ClickUp Token
CLICKUP_TOKEN=your_clickup_token

# ClickUp Team/Workspace ID (optional - speeds up lookups)
CLICKUP_TEAM_ID=your_clickup_team_id

# Discord Webhook URL
DISCORD_WEBHOOK_URL=your_discord_webhook_url
